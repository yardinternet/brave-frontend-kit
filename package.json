{
	"name": "@yardinternet/brave-frontend-kit",
	"version": "0.13.3",
	"type": "module",
	"main": "dist/brave-frontend-kit.js",
	"module": "dist/brave-frontend-kit.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/brave-frontend-kit.js"
		}
	},
	"license": "EUPL-1.2",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yardinternet/brave-frontend-kit.git"
	},
	"files": [
		"dist",
		"src",
		"!**/*.test.*"
	],
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/@yardinternet"
	},
	"scripts": {
		"start": "vite build --watch",
		"build": "vite build",
		"typecheck": "tsc --noEmit",
		"lint:js": "yard-toolkit lint js -m custom './src/**/*.ts' && pnpm run typecheck",
		"format:js": "yard-toolkit format js -m custom './src/**/*.ts'",
		"test": "vitest run",
		"prepare": "husky"
	},
	"devDependencies": {
		"@types/body-scroll-lock": "^3.1.2",
		"@types/headroom.js": "^0.12.4",
		"@yardinternet/eslint-config": "^1.2.12",
		"@yardinternet/prettier-config": "^2.0.11",
		"@yardinternet/toolkit": "^2.1.12",
		"@yardinternet/ts-config": "^1.1.2",
		"@yardinternet/vite-config": "^1.3.5",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.5",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.6",
		"accordion-js": "^3.4.1",
		"body-scroll-lock": "4.0.0-beta.0",
		"focus-trap": "^7.8.0",
		"headroom.js": "^0.12.0"
	},
	"optionalDependencies": {
		"@rollup/rollup-linux-arm64-gnu": "^4.62.0"
	},
	"packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
